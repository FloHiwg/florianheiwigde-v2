{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "trailingSlash": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/private",
        "destination": "/personal",
        "type": 301
      },
      {
        "source": "/private/**",
        "destination": "/personal/:splat",
        "type": 301
      }
    ]
  }
}
